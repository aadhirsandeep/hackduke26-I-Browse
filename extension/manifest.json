{
  "manifest_version": 3,
  "name": "I Browse",
  "version": "1.0.0",
  "description": "AI-powered DOM transformation engine",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"]
    }
  ],
  "side_panel": {
    "default_path": "panel/index.html"
  },
  "action": {
    "default_title": "evolve(browser)"
  },
  "optional_permissions": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": ["raw-audio-processor.js", "audio-concat-processor.js", "talk.html", "elevenlabs.umd.js", "livekit.umd.js", "convai-widget.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
